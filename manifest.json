{
  "manifest_version": 3,
  "name": "Parental Controls for Nintendo Switch",
  "version": "1.1.5",
  "description": "Monitor and manage Nintendo Switch parental controls from your browser",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "https://app.lp1.znma.srv.nintendo.net/*",
    "https://accounts.nintendo.com/*",
    "https://api.accounts.nintendo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
